              "geolocation"
            ],
            "type": "object"
          },
          "Identification": {
            "additionalProperties": false,
            "properties": {
              "browserDetails": {
                "$ref": "#/$defs/BrowserDetails"
              },
              "components": {
                "$ref": "#/$defs/RawDeviceAttributes"
              },
              "confidence": {
                "$ref": "#/$defs/IdentificationConfidence"
              },
              "environmentId": {
                "description": "Environment ID associated with the event",
                "type": "string"
              },
              "firstSeenAt": {
                "$ref": "#/$defs/IdentificationSeenAt"
              },
              "incognito": {
                "description": "Flag if user used incognito session.",
                "type": "boolean"
              },
              "ip": {
                "description": "IP address of the requesting browser or bot.",
                "type": "string"
              },
              "ipLocation": {
                "$ref": "#/$defs/DeprecatedGeolocation"
              },
              "lastSeenAt": {
                "$ref": "#/$defs/IdentificationSeenAt"
              },
              "linkedId": {
                "description": "A customer-provided id that was sent with the request.",
                "type": "string"
              },
              "replayed": {
                "description": "`true` if we determined that this payload was replayed, `false` otherwise.\n",
                "type": "boolean"
              },
              "requestId": {
                "description": "Unique identifier of the user's request.",
                "type": "string"
              },
              "sdk": {
                "$ref": "#/$defs/SDK"
              },
              "suspect": {
                "description": "Field is `true` if you have previously set the `suspect` flag for this event using the [Server API Update event endpoint](https://dev.fingerprint.com/reference/updateevent).",
                "type": "boolean"
              },
              "tag": {
                "$ref": "#/$defs/Tag"
              },
              "time": {
                "description": "Time expressed according to ISO 8601 in UTC format, when the request from the JS agent was made. We recommend to treat requests that are older than 2 minutes as malicious. Otherwise, request replay attacks are possible.",
                "format": "date-time",
                "type": "string"
              },
              "timestamp": {
                "description": "Timestamp of the event with millisecond precision in Unix time.",
                "type": "integer"
              },
              "url": {
                "description": "Page URL from which the request was sent.",
                "type": "string"
              },
              "visitorFound": {
                "description": "Attribute represents if a visitor had been identified before.",
                "type": "boolean"
              },
              "visitorId": {
                "description": "String of 20 characters that uniquely identifies the visitor's browser or mobile device.",
                "type": "string"
              }
            },
            "required": [
              "visitorId",
              "requestId",
              "browserDetails",
              "incognito",
              "ip",
              "timestamp",
              "time",
              "url",
              "tag",
              "visitorFound",
              "firstSeenAt",
              "lastSeenAt",
              "replayed"
            ],
            "type": "object"
          },
          "IdentificationConfidence": {
            "additionalProperties": false,
            "properties": {
              "comment": {
                "type": "string"
              },
              "revision": {
                "description": "The revision name of the method used to calculate the Confidence score. This field is only present for customers who opted in to an alternative calculation method.",
                "type": "string"
              },
              "score": {
                "description": "The confidence score is a floating-point number between 0 and 1 that represents the probability of accurate identification.",
                "maximum": 1,
                "minimum": 0,
                "type": "number"
              }
            },
            "required": [
              "score"
            ],
            "type": "object"
          },
          "IdentificationSeenAt": {
            "additionalProperties": false,
            "properties": {
              "global": {
                "format": "date-time",
                "type": [
                  "string",
                  "null"
                ]
              },
              "subscription": {
                "format": "date-time",
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "global",
              "subscription"
            ],
            "type": "object"
          },
          "Incognito": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "`true` if we detected incognito mode used in the browser, `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "Integration": {
            "additionalProperties": false,
            "properties": {
              "name": {
                "description": "The name of the specific integration, e.g. \"fingerprint-pro-react\".",
                "type": "string"
              },
              "subintegration": {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "description": "The name of the specific subintegration, e.g. \"preact\".",
                    "type": "string"
                  },
                  "version": {
                    "description": "The version of the specific subintegration, e.g. \"10.21.0\".",
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "version": {
                "description": "The version of the specific integration, e.g. \"3.11.10\".",
                "type": "string"
              }
            },
            "type": "object"
          },
          "Jailbroken": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "iOS specific jailbreak detection. There are 2 values: \n  * `true` - Jailbreak detected.\n  * `false` - No signs of jailbreak or the client is not iOS.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "LocationSpoofing": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "Flag indicating whether the request came from a mobile device with location spoofing enabled.",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "MitMAttack": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "* `true` - When requests made from your users' mobile devices to Fingerprint servers have been intercepted and potentially modified. \n* `false` - Otherwise or when the request originated from a browser.\nSee [MitM Attack Detection](https://dev.fingerprint.com/docs/smart-signals-reference#mitm-attack-detection) to learn more about this Smart Signal.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "PrivacySettings": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "`true` if the request is from a privacy aware browser (e.g. Tor) or from a browser in which fingerprinting is blocked. Otherwise `false`.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
