{
  "server": "fingerprint",
  "tools": [
    {
      "name": "create_api_key",
      "description": "Creates a new API key. Requires type (public/secret/proxy) and name (3-255 chars). Secret key tokens are only visible at creation time. For schema, see mcp resource fingerprint://schemas/api-key",
      "inputSchema": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "API key type. Values: public, secret, proxy"
          },
          "name": {
            "type": "string",
            "description": "API key display name (3-255 characters)"
          },
          "description": {
            "type": "string",
            "description": "API key description (3-255 characters)"
          },
          "environment": {
            "type": "string",
            "description": "Environment ID. If omitted for proxy/secret keys, scopes to the workspace"
          }
        },
        "required": [
          "type",
          "name"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "api_key": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Auto-generated API key identifier"
              },
              "name": {
                "type": "string",
                "description": "API key display name"
              },
              "description": {
                "type": "string",
                "description": "API key description"
              },
              "status": {
                "type": "string",
                "description": "API key status. Values: enabled, disabled"
              },
              "environment": {
                "description": "Associated environment. Null if scoped to the workspace"
              },
              "type": {
                "type": "string",
                "description": "API key type. Values: public, secret, proxy"
              },
              "token": {
                "type": "string",
                "description": "API key value. Secret keys are only visible at creation time"
              },
              "rate_limit": {
                "type": "number",
                "description": "Requests-per-second limit for this key"
              },
              "created_at": {
                "type": "string",
                "description": "Timestamp when the API key was created"
              },
              "disabled_at": {
                "type": [
                  "null",
                  "string"
                ],
                "description": "Timestamp when the API key was disabled"
              }
            },
            "description": "The created API key with id, name, description, status, environment, type, token, rate_limit, created_at, and disabled_at. Secret key tokens are only visible at creation time",
            "required": [
              "id",
              "name",
              "description",
              "status",
              "environment",
              "type",
              "token",
              "rate_limit",
              "created_at",
              "disabled_at"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "api_key"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "create_environment",
      "description": "Creates a new workspace environment. Requires a name (3-255 chars). Optionally set description, limit mode (none/restrict/notify), and limit value. For schema, see mcp resource fingerprint://schemas/environment",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Environment display name (3-255 characters)"
          },
          "description": {
            "type": "string",
            "description": "Environment description (max 256 characters)"
          },
          "limit_mode": {
            "type": "string",
            "description": "Limit behavior mode. Values: none, restrict, notify"
          },
          "limit_value": {
            "type": "integer",
            "description": "Threshold value. Required if limit_mode is not none. Minimum: 1"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "environment": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Auto-generated environment identifier"
              },
              "name": {
                "type": "string",
                "description": "Environment display name"
              },
              "description": {
                "type": "string",
                "description": "Environment description (max 256 characters)"
              },
              "limit_mode": {
                "type": "string",
                "description": "Limit behavior mode. Values: none, restrict, notify"
              },
              "limit_value": {
                "type": "integer",
                "description": "Threshold value. Required if limit_mode is not none. Minimum: 1"
              },
              "is_restricted": {
                "type": "boolean",
                "description": "Whether the environment is currently restricted"
              },
              "restricted_at": {
                "type": [
                  "null",
                  "string"
                ],
                "description": "Timestamp when the environment was restricted"
              },
              "created_at": {
                "type": "string",
                "description": "Timestamp when the environment was created"
              },
              "updated_at": {
                "type": [
                  "null",
                  "string"
                ],
                "description": "Timestamp when the environment was last updated"
              }
            },
            "description": "The created environment with id, name, description, limit_mode, limit_value, is_restricted, restricted_at, created_at, and updated_at",
            "required": [
              "id",
              "name",
              "description",
              "limit_mode",
              "limit_value",
              "is_restricted",
              "restricted_at",
              "created_at",
              "updated_at"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "environment"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "delete_api_key",
      "description": "Deletes an API key. This operation is irreversible.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "API key identifier"
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false
      }
    },
    {
      "name": "delete_environment",
      "description": "Deletes a workspace environment. You can only delete environments that don't have any active API keys associated with them.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Environment identifier. You can only delete environments without active API keys"
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false
      }
    },
    {
      "name": "get_api_key",
      "description": "Retrieves detailed information about a specific API key by its ID. For schema, see mcp resource fingerprint://schemas/api-key",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "API key identifier"
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "api_key": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Auto-generated API key identifier"
              },
              "name": {
                "type": "string",
                "description": "API key display name"
              },
              "description": {
                "type": "string",
                "description": "API key description"
              },
              "status": {
                "type": "string",
                "description": "API key status. Values: enabled, disabled"
              },
              "environment": {
                "description": "Associated environment. Null if scoped to the workspace"
              },
              "type": {
                "type": "string",
                "description": "API key type. Values: public, secret, proxy"
              },
              "token": {
                "type": "string",
                "description": "API key value. Secret keys are only visible at creation time"
              },
              "rate_limit": {
                "type": "number",
                "description": "Requests-per-second limit for this key"
              },
              "created_at": {
                "type": "string",
                "description": "Timestamp when the API key was created"
              },
              "disabled_at": {
                "type": [
                  "null",
                  "string"
                ],
                "description": "Timestamp when the API key was disabled"
              }
            },
            "description": "The API key with id, name, description, status, environment, type, token, rate_limit, created_at, and disabled_at",
            "required": [
              "id",
              "name",
              "description",
              "status",
              "environment",
              "type",
              "token",
              "rate_limit",
              "created_at",
              "disabled_at"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "api_key"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "get_event",
      "description": "Retrieves detailed information about a specific identification event from Fingerprint using its event_id. Returns comprehensive data including visitor_id, browser details, geolocation, bot detection, and various smart signals for fraud detection. For schema, see mcp resource fingerprint://schemas/event",
      "inputSchema": {
        "type": "object",
        "properties": {
          "event_id": {
            "description": "The unique identifier of the identification event to retrieve",
            "type": "string"
          },
          "products": {
            "description": "Optional list of product fields to include in the response. If omitted all products are returned.",
            "items": {
              "enum": [
                "botd",
                "clonedApp",
                "developerTools",
                "emulator",
                "factoryReset",
                "frida",
                "highActivity",
                "identification",
                "incognito",
                "ipBlocklist",
                "ipInfo",
                "jailbroken",
                "locationSpoofing",
                "mitmAttack",
                "privacySettings",
                "proximity",
                "proxy",
                "rawDeviceAttributes",
                "remoteControl",
                "rootApps",
                "suspectScore",
                "tampering",
                "tor",
                "velocity",
                "virtualMachine",
                "vpn"
              ],
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "event_id"
        ],
        "$defs": {
          "Botd": {
            "additionalProperties": false,
            "description": "Contains all the information from Bot Detection product",
            "properties": {
              "bot": {
                "$ref": "#/$defs/BotdBot"
              },
              "ip": {
                "description": "IP address of the requesting browser or bot.",
                "type": "string"
              },
              "linkedId": {
                "description": "A customer-provided id that was sent with the request.",
                "type": "string"
              },
              "meta": {
                "$ref": "#/$defs/Tag"
              },
              "requestId": {
                "description": "Unique identifier of the user's request.",
                "type": "string"
              },
              "time": {
                "description": "Time in UTC when the request from the JS agent was made. We recommend to treat requests that are older than 2 minutes as malicious. Otherwise, request replay attacks are possible.",
                "format": "date-time",
                "type": "string"
              },
              "url": {
                "description": "Page URL from which the request was sent.",
                "type": "string"
              },
              "userAgent": {
                "type": "string"
              }
            },
            "required": [
              "bot",
              "url",
              "ip",
              "time",
              "userAgent",
              "requestId"
            ],
            "type": "object"
          },
          "BotdBot": {
            "additionalProperties": false,
            "description": "Stores bot detection result",
            "properties": {
              "result": {
                "$ref": "#/$defs/BotdBotResult"
              },
              "type": {
                "type": "string"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "BotdBotResult": {
            "description": "Bot detection result:\n * `notDetected` - the visitor is not a bot\n * `good` - good bot detected, such as Google bot, Baidu Spider, AlexaBot and so on\n * `bad` - bad bot detected, such as Selenium, Puppeteer, Playwright, headless browsers, and so on\n",
            "enum": [
              "notDetected",
              "good",
              "bad"
            ],
            "type": "string"
          },
          "BrowserDetails": {
            "additionalProperties": false,
            "properties": {
              "browserFullVersion": {
                "type": "string"
              },
              "browserMajorVersion": {
                "type": "string"
              },
              "browserName": {
                "type": "string"
              },
              "device": {
                "type": "string"
              },
              "os": {
                "type": "string"
              },
              "osVersion": {
                "type": "string"
              },
              "userAgent": {
                "type": "string"
              }
            },
            "required": [
              "browserName",
              "browserFullVersion",
              "browserMajorVersion",
              "os",
              "osVersion",
              "device",
              "userAgent"
            ],
            "type": "object"
          },
          "ClonedApp": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "Android specific cloned application detection. There are 2 values: \n  * `true` - Presence of app cloners work detected (e.g. fully cloned application found or launch of it inside of a not main working profile detected).\n  * `false` - No signs of cloned application detected or the client is not Android.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "DeprecatedGeolocation": {
            "additionalProperties": false,
            "description": "This field is **deprecated** and will not return a result for **applications created after January 23rd, 2024**.  Please use the [IP Geolocation Smart signal](https://dev.fingerprint.com/docs/smart-signals-overview#ip-geolocation) for geolocation information.",
            "properties": {
              "accuracyRadius": {
                "description": "The IP address is likely to be within this radius (in km) of the specified location.",
                "minimum": 0,
                "type": "integer"
              },
              "city": {
                "$ref": "#/$defs/GeolocationCity"
              },
              "continent": {
                "$ref": "#/$defs/GeolocationContinent"
              },
              "country": {
                "$ref": "#/$defs/GeolocationCountry"
              },
              "latitude": {
                "maximum": 90,
                "minimum": -90,
                "type": "number"
              },
              "longitude": {
                "maximum": 180,
                "minimum": -180,
                "type": "number"
              },
              "postalCode": {
                "type": "string"
              },
              "subdivisions": {
                "$ref": "#/$defs/GeolocationSubdivisions"
              },
              "timezone": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "DeveloperTools": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "`true` if the browser is Chrome with DevTools open or Firefox with Developer Tools open, `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "Emulator": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "Android specific emulator detection. There are 2 values: \n  * `true` - Emulated environment detected (e.g. launch inside of AVD). \n  * `false` - No signs of emulated environment detected or the client is not Android.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "Error": {
            "additionalProperties": false,
            "properties": {
              "code": {
                "$ref": "#/$defs/ErrorCode"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "type": "object"
          },
          "ErrorCode": {
            "description": "Error code:\n * `RequestCannotBeParsed` - the query parameters or JSON payload contains some errors \n          that prevented us from parsing it (wrong type/surpassed limits).\n * `TokenRequired` - `Auth-API-Key` header is missing or empty.\n * `TokenNotFound` - no Fingerprint application found for specified secret key.\n * `SubscriptionNotActive` - Fingerprint application is not active.\n * `WrongRegion` - server and application region differ.\n * `FeatureNotEnabled` - this feature (for example, Delete API) is not enabled for your application.\n * `WorkspaceScopedSecretKeyRequired` - The provided secret API key is scoped to an environment, but this operation requires a workspace-scoped secret API key.\n * `RequestNotFound` - the specified request ID was not found. It never existed, expired, or it has been deleted.\n * `VisitorNotFound` - The specified visitor ID was not found. It never existed or it may have already been deleted.\n * `TooManyRequests` - the limit on secret API key requests per second has been exceeded.\n * `429 Too Many Requests` - the limit on secret API key requests per second has been exceeded.\n * `StateNotReady` - The event specified with request id is\n          not ready for updates yet. Try again.\n          This error happens in rare cases when update API is called immediately\n          after receiving the request id on the client. In case you need to send\n          information right away, we recommend using the JS agent API instead.\n * `Failed` - internal server error.\n",
            "enum": [
              "RequestCannotBeParsed",
              "TokenRequired",
              "TokenNotFound",
              "SubscriptionNotActive",
              "WrongRegion",
              "FeatureNotEnabled",
              "WorkspaceScopedSecretKeyRequired",
              "RequestNotFound",
              "VisitorNotFound",
              "TooManyRequests",
              "429 Too Many Requests",
              "StateNotReady",
              "Failed"
            ],
            "type": "string"
          },
          "EventsGetResponse": {
            "additionalProperties": false,
            "description": "Contains results from Fingerprint Identification and all active Smart Signals.",
            "properties": {
              "products": {
                "$ref": "#/$defs/Products"
              }
            },
            "required": [
              "products"
            ],
            "type": "object"
          },
          "FactoryReset": {
            "additionalProperties": false,
            "properties": {
              "time": {
                "description": "Indicates the time (in UTC) of the most recent factory reset that happened on the **mobile device**. \nWhen a factory reset cannot be detected on the mobile device or when the request is initiated from a browser,  this field will correspond to the *epoch* time (i.e 1 Jan 1970 UTC).\nSee [Factory Reset Detection](https://dev.fingerprint.com/docs/smart-signals-overview#factory-reset-detection) to learn more about this Smart Signal.\n",
                "format": "date-time",
                "type": "string"
              },
              "timestamp": {
                "description": "This field is just another representation of the value in the `time` field.\nThe time of the most recent factory reset that happened on the **mobile device** is expressed as Unix epoch time.\n",
                "type": "integer"
              }
            },
            "required": [
              "time",
              "timestamp"
            ],
            "type": "object"
          },
          "Frida": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "[Frida](https://frida.re/docs/) detection for Android and iOS devices. There are 2 values:\n  * `true` - Frida detected\n  * `false` - No signs of Frida or the client is not a mobile device.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "Geolocation": {
            "additionalProperties": false,
            "properties": {
              "accuracyRadius": {
                "description": "The IP address is likely to be within this radius (in km) of the specified location.",
                "minimum": 0,
                "type": "integer"
              },
              "city": {
                "$ref": "#/$defs/GeolocationCity"
              },
              "continent": {
                "$ref": "#/$defs/GeolocationContinent"
              },
              "country": {
                "$ref": "#/$defs/GeolocationCountry"
              },
              "latitude": {
                "maximum": 90,
                "minimum": -90,
                "type": "number"
              },
              "longitude": {
                "maximum": 180,
                "minimum": -180,
                "type": "number"
              },
              "postalCode": {
                "type": "string"
              },
              "subdivisions": {
                "$ref": "#/$defs/GeolocationSubdivisions"
              },
              "timezone": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "GeolocationCity": {
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "type": "object"
          },
          "GeolocationContinent": {
            "additionalProperties": false,
            "properties": {
              "code": {
                "maxLength": 2,
                "minLength": 2,
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "name"
            ],
            "type": "object"
          },
          "GeolocationCountry": {
            "additionalProperties": false,
            "properties": {
              "code": {
                "maxLength": 2,
                "minLength": 2,
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "name"
            ],
            "type": "object"
          },
          "GeolocationSubdivision": {
            "additionalProperties": false,
            "properties": {
              "isoCode": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "isoCode",
              "name"
            ],
            "type": "object"
          },
          "GeolocationSubdivisions": {
            "items": {
              "$ref": "#/$defs/GeolocationSubdivision"
            },
            "type": "array"
          },
          "HighActivity": {
            "additionalProperties": false,
            "properties": {
              "dailyRequests": {
                "description": "Number of requests from the same visitor in the previous day.",
                "minimum": 1,
                "type": "integer"
              },
              "result": {
                "description": "Flag indicating if the request came from a high-activity visitor.",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "IPBlocklist": {
            "additionalProperties": false,
            "properties": {
              "details": {
                "$ref": "#/$defs/IPBlocklistDetails"
              },
              "result": {
                "description": "`true` if request IP address is part of any database that we use to search for known malicious actors, `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result",
              "details"
            ],
            "type": "object"
          },
          "IPBlocklistDetails": {
            "additionalProperties": false,
            "properties": {
              "attackSource": {
                "description": "IP address was part of a known network attack (SSH/HTTPS).",
                "type": "boolean"
              },
              "emailSpam": {
                "description": "IP address was part of a known email spam attack (SMTP).",
                "type": "boolean"
              }
            },
            "required": [
              "emailSpam",
              "attackSource"
            ],
            "type": "object"
          },
          "IPInfo": {
            "additionalProperties": false,
            "description": "Details about the request IP address. Has separate fields for v4 and v6 IP address versions.",
            "properties": {
              "v4": {
                "$ref": "#/$defs/IPInfoV4"
              },
              "v6": {
                "$ref": "#/$defs/IPInfoV6"
              }
            },
            "type": "object"
          },
          "IPInfoASN": {
            "additionalProperties": false,
            "properties": {
              "asn": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "network": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            },
            "required": [
              "asn",
              "name",
              "network"
            ],
            "type": "object"
          },
          "IPInfoDataCenter": {
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "result": {
                "type": "boolean"
              }
            },
            "required": [
              "result",
              "name"
            ],
            "type": "object"
          },
          "IPInfoV4": {
            "additionalProperties": false,
            "properties": {
              "address": {
                "format": "ipv4",
                "type": "string"
              },
              "asn": {
                "$ref": "#/$defs/IPInfoASN"
              },
              "datacenter": {
                "$ref": "#/$defs/IPInfoDataCenter"
              },
              "geolocation": {
                "$ref": "#/$defs/Geolocation"
              }
            },
            "required": [
              "address",
              "geolocation"
            ],
            "type": "object"
          },
          "IPInfoV6": {
            "additionalProperties": false,
            "properties": {
              "address": {
                "format": "ipv6",
                "type": "string"
              },
              "asn": {
                "$ref": "#/$defs/IPInfoASN"
              },
              "datacenter": {
                "$ref": "#/$defs/IPInfoDataCenter"
              },
              "geolocation": {
                "$ref": "#/$defs/Geolocation"
              }
            },
            "required": [
              "address",
              "geolocation"
            ],
            "type": "object"
          },
          "Identification": {
            "additionalProperties": false,
            "properties": {
              "browserDetails": {
                "$ref": "#/$defs/BrowserDetails"
              },
              "components": {
                "$ref": "#/$defs/RawDeviceAttributes"
              },
              "confidence": {
                "$ref": "#/$defs/IdentificationConfidence"
              },
              "environmentId": {
                "description": "Environment ID associated with the event",
                "type": "string"
              },
              "firstSeenAt": {
                "$ref": "#/$defs/IdentificationSeenAt"
              },
              "incognito": {
                "description": "Flag if user used incognito session.",
                "type": "boolean"
              },
              "ip": {
                "description": "IP address of the requesting browser or bot.",
                "type": "string"
              },
              "ipLocation": {
                "$ref": "#/$defs/DeprecatedGeolocation"
              },
              "lastSeenAt": {
                "$ref": "#/$defs/IdentificationSeenAt"
              },
              "linkedId": {
                "description": "A customer-provided id that was sent with the request.",
                "type": "string"
              },
              "replayed": {
                "description": "`true` if we determined that this payload was replayed, `false` otherwise.\n",
                "type": "boolean"
              },
              "requestId": {
                "description": "Unique identifier of the user's request.",
                "type": "string"
              },
              "sdk": {
                "$ref": "#/$defs/SDK"
              },
              "suspect": {
                "description": "Field is `true` if you have previously set the `suspect` flag for this event using the [Server API Update event endpoint](https://dev.fingerprint.com/reference/updateevent).",
                "type": "boolean"
              },
              "tag": {
                "$ref": "#/$defs/Tag"
              },
              "time": {
                "description": "Time expressed according to ISO 8601 in UTC format, when the request from the JS agent was made. We recommend to treat requests that are older than 2 minutes as malicious. Otherwise, request replay attacks are possible.",
                "format": "date-time",
                "type": "string"
              },
              "timestamp": {
                "description": "Timestamp of the event with millisecond precision in Unix time.",
                "type": "integer"
              },
              "url": {
                "description": "Page URL from which the request was sent.",
                "type": "string"
              },
              "visitorFound": {
                "description": "Attribute represents if a visitor had been identified before.",
                "type": "boolean"
              },
              "visitorId": {
                "description": "String of 20 characters that uniquely identifies the visitor's browser or mobile device.",
                "type": "string"
              }
            },
            "required": [
              "visitorId",
              "requestId",
              "browserDetails",
              "incognito",
              "ip",
              "timestamp",
              "time",
              "url",
              "tag",
              "visitorFound",
              "firstSeenAt",
              "lastSeenAt",
              "replayed"
            ],
            "type": "object"
          },
          "IdentificationConfidence": {
            "additionalProperties": false,
            "properties": {
              "comment": {
                "type": "string"
              },
              "revision": {
                "description": "The revision name of the method used to calculate the Confidence score. This field is only present for customers who opted in to an alternative calculation method.",
                "type": "string"
              },
              "score": {
                "description": "The confidence score is a floating-point number between 0 and 1 that represents the probability of accurate identification.",
                "maximum": 1,
                "minimum": 0,
                "type": "number"
              }
            },
            "required": [
              "score"
            ],
            "type": "object"
          },
          "IdentificationSeenAt": {
            "additionalProperties": false,
            "properties": {
              "global": {
                "format": "date-time",
                "type": [
                  "string",
                  "null"
                ]
              },
              "subscription": {
                "format": "date-time",
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "global",
              "subscription"
            ],
            "type": "object"
          },
          "Incognito": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "`true` if we detected incognito mode used in the browser, `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "Integration": {
            "additionalProperties": false,
            "properties": {
              "name": {
                "description": "The name of the specific integration, e.g. \"fingerprint-pro-react\".",
                "type": "string"
              },
              "subintegration": {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "description": "The name of the specific subintegration, e.g. \"preact\".",
                    "type": "string"
                  },
                  "version": {
                    "description": "The version of the specific subintegration, e.g. \"10.21.0\".",
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "version": {
                "description": "The version of the specific integration, e.g. \"3.11.10\".",
                "type": "string"
              }
            },
            "type": "object"
          },
          "Jailbroken": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "iOS specific jailbreak detection. There are 2 values: \n  * `true` - Jailbreak detected.\n  * `false` - No signs of jailbreak or the client is not iOS.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "LocationSpoofing": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "Flag indicating whether the request came from a mobile device with location spoofing enabled.",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "MitMAttack": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "* `true` - When requests made from your users' mobile devices to Fingerprint servers have been intercepted and potentially modified. \n* `false` - Otherwise or when the request originated from a browser.\nSee [MitM Attack Detection](https://dev.fingerprint.com/docs/smart-signals-reference#mitm-attack-detection) to learn more about this Smart Signal.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "PrivacySettings": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "`true` if the request is from a privacy aware browser (e.g. Tor) or from a browser in which fingerprinting is blocked. Otherwise `false`.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
