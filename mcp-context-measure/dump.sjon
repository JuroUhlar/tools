          },
          "Products": {
            "additionalProperties": false,
            "description": "Contains all information about the request identified by `requestId`, depending on the pricing plan (Pro, Pro Plus, Enterprise)",
            "properties": {
              "botd": {
                "$ref": "#/$defs/ProductBotd"
              },
              "clonedApp": {
                "$ref": "#/$defs/ProductClonedApp"
              },
              "developerTools": {
                "$ref": "#/$defs/ProductDeveloperTools"
              },
              "emulator": {
                "$ref": "#/$defs/ProductEmulator"
              },
              "factoryReset": {
                "$ref": "#/$defs/ProductFactoryReset"
              },
              "frida": {
                "$ref": "#/$defs/ProductFrida"
              },
              "highActivity": {
                "$ref": "#/$defs/ProductHighActivity"
              },
              "identification": {
                "$ref": "#/$defs/ProductIdentification"
              },
              "incognito": {
                "$ref": "#/$defs/ProductIncognito"
              },
              "ipBlocklist": {
                "$ref": "#/$defs/ProductIPBlocklist"
              },
              "ipInfo": {
                "$ref": "#/$defs/ProductIPInfo"
              },
              "jailbroken": {
                "$ref": "#/$defs/ProductJailbroken"
              },
              "locationSpoofing": {
                "$ref": "#/$defs/ProductLocationSpoofing"
              },
              "mitmAttack": {
                "$ref": "#/$defs/ProductMitMAttack"
              },
              "privacySettings": {
                "$ref": "#/$defs/ProductPrivacySettings"
              },
              "proximity": {
                "$ref": "#/$defs/ProductProximity"
              },
              "proxy": {
                "$ref": "#/$defs/ProductProxy"
              },
              "rawDeviceAttributes": {
                "$ref": "#/$defs/ProductRawDeviceAttributes"
              },
              "remoteControl": {
                "$ref": "#/$defs/ProductRemoteControl"
              },
              "rootApps": {
                "$ref": "#/$defs/ProductRootApps"
              },
              "suspectScore": {
                "$ref": "#/$defs/ProductSuspectScore"
              },
              "tampering": {
                "$ref": "#/$defs/ProductTampering"
              },
              "tor": {
                "$ref": "#/$defs/ProductTor"
              },
              "velocity": {
                "$ref": "#/$defs/ProductVelocity"
              },
              "virtualMachine": {
                "$ref": "#/$defs/ProductVirtualMachine"
              },
              "vpn": {
                "$ref": "#/$defs/ProductVPN"
              }
            },
            "type": "object"
          },
          "Proximity": {
            "additionalProperties": false,
            "description": "Proximity ID represents a fixed geographical zone in a discrete global grid within which the device is observed.\n",
            "properties": {
              "confidence": {
                "description": "A value between `0` and `1` representing the likelihood that the true device location lies within the mapped proximity zone.\n  * Scores closer to `1` indicate high confidence that the location is inside the mapped proximity zone.\n  * Scores closer to `0` indicate lower confidence, suggesting the true location may fall in an adjacent zone.\n",
                "maximum": 1,
                "minimum": 0,
                "type": "number"
              },
              "id": {
                "description": "A stable privacy-preserving identifier for a given proximity zone.\n",
                "type": "string"
              },
              "precisionRadius": {
                "description": "The radius of the proximity zone’s precision level, in meters.\n",
                "enum": [
                  10,
                  25,
                  65,
                  175,
                  450,
                  1200,
                  3300,
                  8500,
                  22500
                ],
                "type": "integer"
              }
            },
            "required": [
              "id",
              "precisionRadius",
              "confidence"
            ],
            "type": "object"
          },
          "Proxy": {
            "additionalProperties": false,
            "properties": {
              "confidence": {
                "$ref": "#/$defs/ProxyConfidence"
              },
              "details": {
                "$ref": "#/$defs/ProxyDetails"
              },
              "result": {
                "description": "IP address was used by a public proxy provider or belonged to a known recent residential proxy\n",
                "type": "boolean"
              }
            },
            "required": [
              "result",
              "confidence"
            ],
            "type": "object"
          },
          "ProxyConfidence": {
            "description": "Confidence level of the proxy detection.\nIf a proxy is not detected, confidence is \"high\".\nIf it's detected, can be \"low\", \"medium\", or \"high\".\n",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "ProxyDetails": {
            "additionalProperties": false,
            "description": "Proxy detection details (present if proxy is detected)",
            "properties": {
              "lastSeenAt": {
                "description": "ISO 8601 formatted timestamp in UTC with hourly resolution\nof when this IP was last seen as a proxy when available.\n",
                "format": "date-time",
                "type": "string"
              },
              "proxyType": {
                "description": "Residential proxies use real user IP addresses to appear as legitimate traffic, \nwhile data center proxies are public proxies hosted in data centers\n",
                "enum": [
                  "residential",
                  "data_center"
                ],
                "type": "string"
              }
            },
            "required": [
              "proxyType"
            ],
            "type": [
              "object",
              "null"
            ]
          },
          "RawDeviceAttribute": {
            "additionalProperties": false,
            "properties": {
              "error": {
                "$ref": "#/$defs/RawDeviceAttributeError"
              },
              "value": {
                "title": "value"
              }
            },
            "type": "object"
          },
          "RawDeviceAttributeError": {
            "additionalProperties": false,
            "properties": {
              "message": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "RawDeviceAttributes": {
            "additionalProperties": {
              "$ref": "#/$defs/RawDeviceAttribute"
            },
            "description": "It includes 35+ raw browser identification attributes to provide Fingerprint users with even more information than our standard visitor ID provides. This enables Fingerprint users to not have to run our open-source product in conjunction with Fingerprint Pro Plus and Enterprise to get those additional attributes.\nWarning: The raw signals data can change at any moment as we improve the product. We cannot guarantee the internal shape of raw device attributes to be stable, so typical semantic versioning rules do not apply here. Use this data with caution without assuming a specific structure beyond the generic type provided here.\n",
            "type": "object"
          },
          "RemoteControl": {
            "additionalProperties": false,
            "description": "This signal is deprecated.\n",
            "properties": {
              "result": {
                "description": "`true` if the request came from a machine being remotely controlled (e.g. TeamViewer), `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "RootApps": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "Android specific root management apps detection. There are 2 values: \n  * `true` - Root Management Apps detected (e.g. Magisk).\n  * `false` - No Root Management Apps detected or the client isn't Android.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "SDK": {
            "additionalProperties": false,
            "description": "Contains information about the SDK used to perform the request.",
            "properties": {
              "integrations": {
                "items": {
                  "$ref": "#/$defs/Integration"
                },
                "type": "array"
              },
              "platform": {
                "description": "Platform of the SDK.",
                "type": "string"
              },
              "version": {
                "description": "SDK version string.",
                "type": "string"
              }
            },
            "required": [
              "platform",
              "version"
            ],
            "type": "object"
          },
          "SearchEventsResponse": {
            "additionalProperties": false,
            "description": "Contains a list of all identification events matching the specified search criteria.",
            "properties": {
              "events": {
                "items": {
                  "description": "Device intelligence results for the identification event.",
                  "properties": {
                    "products": {
                      "$ref": "#/$defs/Products"
                    }
                  },
                  "required": [
                    "products"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "paginationKey": {
                "description": "Use this value in the `pagination_key` parameter to request the next page of search results.",
                "type": "string"
              }
            },
            "type": "object"
          },
          "SuspectScore": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "Suspect Score is an easy way to integrate Smart Signals into your fraud protection work flow.  It is a weighted representation of all Smart Signals present in the payload that helps identify suspicious activity. The value range is [0; S] where S is sum of all Smart Signals weights.  See more details here: https://dev.fingerprint.com/docs/suspect-score\n",
                "type": "integer"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "Tag": {
            "additionalProperties": true,
            "description": "A customer-provided value or an object that was sent with identification request.",
            "type": "object"
          },
          "Tampering": {
            "additionalProperties": false,
            "properties": {
              "anomalyScore": {
                "description": "A score that indicates the extent of anomalous data in the request. This field applies to requests originating from **both** browsers and Android SDKs. \n  * Values above `0.5` indicate that the request has been tampered with.\n  * Values below `0.5` indicate that the request is genuine.\n",
                "maximum": 1,
                "minimum": 0,
                "type": "number"
              },
              "antiDetectBrowser": {
                "description": "Anti-detect browsers try to evade identification by masking or manipulating their fingerprint to imitate legitimate browser configurations. This field does not apply to requests originating from mobile SDKs.\n  * `true` - The browser resembles a known anti-detect browser, for example, Incognition.\n  * `false` - The browser does not resemble an anti-detect browser or the request originates from a mobile SDK.\n",
                "type": "boolean"
              },
              "result": {
                "description": "Indicates if an identification request from a browser or an Android SDK has been tampered with. Not supported in the iOS SDK, is always `false` for iOS requests.\n  * `true` - If the request meets either of the following conditions:\n    * Contains anomalous browser or device attributes that could not have been legitimately produced by the JavaScript agent or the Android SDK (see `anomalyScore`).\n    * Originated from an anti-detect browser like Incognition (see `antiDetectBrowser`).\n  * `false` - If the request is considered genuine or was generated by the iOS SDK.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result",
              "anomalyScore",
              "antiDetectBrowser"
            ],
            "type": "object"
          },
          "Tor": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "`true` if the request IP address is a known tor exit node, `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "VPN": {
            "additionalProperties": false,
            "properties": {
              "confidence": {
                "$ref": "#/$defs/VPNConfidence"
              },
              "methods": {
                "$ref": "#/$defs/VPNMethods"
              },
              "originCountry": {
                "description": "Country of the request (only for Android SDK version >= 2.4.0, ISO 3166 format or unknown).",
                "type": "string"
              },
              "originTimezone": {
                "description": "Local timezone which is used in timezoneMismatch method.",
                "type": "string"
              },
              "result": {
                "description": "VPN or other anonymizing service has been used when sending the request.",
                "type": "boolean"
              }
            },
            "required": [
              "result",
              "confidence",
              "originTimezone",
              "originCountry",
              "methods"
            ],
            "type": "object"
          },
          "VPNConfidence": {
            "description": "A confidence rating for the VPN detection result — \"low\", \"medium\", or \"high\". Depends on the combination of results returned from all VPN detection methods.",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "VPNMethods": {
            "additionalProperties": false,
            "properties": {
              "auxiliaryMobile": {
                "description": "This method applies to mobile devices only. Indicates the result of additional methods used to detect a VPN in mobile devices.",
                "type": "boolean"
              },
              "osMismatch": {
                "description": "The browser runs on a different operating system than the operating system inferred from the request network signature.",
                "type": "boolean"
              },
              "publicVPN": {
                "description": "Request IP address is owned and used by a public VPN service provider.",
                "type": "boolean"
              },
              "relay": {
                "description": "Request IP address belongs to a relay service provider, indicating the use of relay services like [Apple Private relay](https://support.apple.com/en-us/102602) or [Cloudflare Warp](https://developers.cloudflare.com/warp-client/). \n\n* Like VPNs, relay services anonymize the visitor's true IP address.\n* Unlike traditional VPNs, relay services don't let visitors spoof their location by choosing an exit node in a different country.\n\nThis field allows you to differentiate VPN users and relay service users in your fraud prevention logic.\n",
                "type": "boolean"
              },
              "timezoneMismatch": {
                "description": "The browser timezone doesn't match the timezone inferred from the request IP address.",
                "type": "boolean"
              }
            },
            "required": [
              "timezoneMismatch",
              "publicVPN",
              "auxiliaryMobile",
              "osMismatch",
              "relay"
            ],
            "type": "object"
          },
          "Velocity": {
            "additionalProperties": false,
            "description": "Sums key data points for a specific `visitorId`, `ipAddress` and `linkedId` at three distinct time\nintervals: 5 minutes, 1 hour, and 24 hours as follows: \n\n- Number of distinct IP addresses associated to the visitor ID.\n- Number of distinct linked IDs associated with the visitor ID.\n- Number of distinct countries associated with the visitor ID.\n- Number of identification events associated with the visitor ID.\n- Number of identification events associated with the detected IP address.\n- Number of distinct IP addresses associated with the provided linked ID.\n- Number of distinct visitor IDs associated with the provided linked ID.\n\nThe `24h` interval of `distinctIp`, `distinctLinkedId`, `distinctCountry`,\n`distinctIpByLinkedId` and `distinctVisitorIdByLinkedId` will be omitted \nif the number of `events` for the visitor ID in the last 24\nhours (`events.intervals.['24h']`) is higher than 20.000.\n",
            "properties": {
              "distinctCountry": {
                "$ref": "#/$defs/VelocityData"
              },
              "distinctIp": {
                "$ref": "#/$defs/VelocityData"
              },
              "distinctIpByLinkedId": {
                "$ref": "#/$defs/VelocityData"
              },
              "distinctLinkedId": {
                "$ref": "#/$defs/VelocityData"
              },
              "distinctVisitorIdByLinkedId": {
                "$ref": "#/$defs/VelocityData"
              },
              "events": {
                "$ref": "#/$defs/VelocityData"
              },
              "ipEvents": {
                "$ref": "#/$defs/VelocityData"
              }
            },
            "required": [
              "distinctIp",
              "distinctLinkedId",
              "distinctCountry",
              "events",
              "ipEvents",
              "distinctIpByLinkedId",
              "distinctVisitorIdByLinkedId"
            ],
            "type": "object"
          },
          "VelocityData": {
            "additionalProperties": false,
            "properties": {
              "intervals": {
                "$ref": "#/$defs/VelocityIntervals"
              }
            },
            "type": "object"
          },
          "VelocityIntervals": {
            "additionalProperties": false,
            "description": "Is absent if the velocity data could not be generated for the visitor ID.\n",
            "properties": {
              "1h": {
                "type": "integer"
              },
              "24h": {
                "description": "The `24h` interval of `distinctIp`, `distinctLinkedId`, `distinctCountry`, `distinctIpByLinkedId` and `distinctVisitorIdByLinkedId` will be omitted if the number of `events`` for the visitor ID in the last 24 hours (`events.intervals.['24h']`) is higher than 20.000.\n",
                "type": "integer"
              },
              "5m": {
                "type": "integer"
              }
            },
            "required": [
              "5m",
              "1h"
            ],
            "type": "object"
          },
          "VirtualMachine": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "`true` if the request came from a browser running inside a virtual machine (e.g. VMWare), `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "list_api_keys",
      "description": "Lists API keys with optional filters by type (public/secret/proxy), status (enabled/disabled), and environment. Supports pagination. For schema, see mcp resource fingerprint://schemas/api-key",
      "inputSchema": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Filter by key type. Values: public, secret, proxy"
          },
          "status": {
            "type": "string",
            "description": "Filter by key status. Values: enabled, disabled"
          },
          "environment": {
            "type": "string",
            "description": "Filter by environment ID"
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor for retrieving items after given position"
          },
          "limit": {
            "type": "integer",
            "description": "Maximum items per page (0-101, default: 10)"
          }
        },
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "api_keys": {
            "type": "object",
            "properties": {
              "data": {
                "type": [
                  "null",
                  "array"
                ],
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Auto-generated API key identifier"
                    },
                    "name": {
                      "type": "string",
                      "description": "API key display name"
                    },
                    "description": {
                      "type": "string",
                      "description": "API key description"
                    },
                    "status": {
                      "type": "string",
                      "description": "API key status. Values: enabled, disabled"
                    },
                    "environment": {
                      "description": "Associated environment. Null if scoped to the workspace"
                    },
                    "type": {
                      "type": "string",
                      "description": "API key type. Values: public, secret, proxy"
                    },
                    "token": {
                      "type": "string",
                      "description": "API key value. Secret keys are only visible at creation time"
                    },
                    "rate_limit": {
                      "type": "number",
                      "description": "Requests-per-second limit for this key"
                    },
                    "created_at": {
                      "type": "string",
                      "description": "Timestamp when the API key was created"
                    },
                    "disabled_at": {
                      "type": [
                        "null",
                        "string"
                      ],
                      "description": "Timestamp when the API key was disabled"
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "description",
                    "status",
                    "environment",
                    "type",
                    "token",
                    "rate_limit",
                    "created_at",
                    "disabled_at"
                  ],
                  "additionalProperties": false
                },
                "description": "List of API keys"
              },
              "metadata": {
                "type": "object",
                "properties": {
                  "pagination": {
                    "type": "object",
                    "properties": {
                      "next_cursor": {
                        "type": [
                          "null",
                          "string"
                        ],
                        "description": "Token for advancing to the next page of results"
                      },
                      "prev_cursor": {
                        "type": [
                          "null",
                          "string"
                        ],
                        "description": "Token for navigating to the previous page of results"
                      }
                    },
                    "description": "Pagination cursors for navigating results",
                    "required": [
                      "next_cursor",
                      "prev_cursor"
                    ],
                    "additionalProperties": false
                  }
                },
                "description": "Response metadata including pagination",
                "required": [
                  "pagination"
                ],
                "additionalProperties": false
              }
            },
            "description": "Paginated list of API keys with metadata containing pagination cursors",
            "required": [
              "data",
              "metadata"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "api_keys"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "list_environments",
      "description": "Lists all workspace environments. Returns environment details including name, description, limits, and restriction status. For schema, see mcp resource fingerprint://schemas/environment",
      "inputSchema": {
        "type": "object",
        "properties": {
          "cursor": {
            "type": "string",
            "description": "Pagination cursor for retrieving items after given position"
          },
          "limit": {
            "type": "integer",
            "description": "Maximum items per page (0-101, default: 10)"
          }
        },
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "environments": {
            "type": "object",
            "properties": {
              "data": {
                "type": [
                  "null",
                  "array"
                ],
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Auto-generated environment identifier"
                    },
                    "name": {
                      "type": "string",
                      "description": "Environment display name"
                    },
                    "description": {
                      "type": "string",
                      "description": "Environment description (max 256 characters)"
                    },
                    "limit_mode": {
                      "type": "string",
                      "description": "Limit behavior mode. Values: none, restrict, notify"
                    },
                    "limit_value": {
                      "type": "integer",
                      "description": "Threshold value. Required if limit_mode is not none. Minimum: 1"
                    },
                    "is_restricted": {
                      "type": "boolean",
                      "description": "Whether the environment is currently restricted"
                    },
                    "restricted_at": {
                      "type": [
                        "null",
                        "string"
                      ],
                      "description": "Timestamp when the environment was restricted"
                    },
                    "created_at": {
                      "type": "string",
                      "description": "Timestamp when the environment was created"
                    },
                    "updated_at": {
                      "type": [
                        "null",
                        "string"
                      ],
                      "description": "Timestamp when the environment was last updated"
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "description",
                    "limit_mode",
                    "limit_value",
                    "is_restricted",
                    "restricted_at",
                    "created_at",
                    "updated_at"
                  ],
                  "additionalProperties": false
                },
                "description": "List of environments"
              },
              "metadata": {
                "type": "object",
                "properties": {
                  "pagination": {
                    "type": "object",
                    "properties": {
                      "next_cursor": {
                        "type": [
                          "null",
                          "string"
                        ],
                        "description": "Token for advancing to the next page of results"
                      },
                      "prev_cursor": {
                        "type": [
                          "null",
                          "string"
                        ],
                        "description": "Token for navigating to the previous page of results"
                      }
                    },
                    "description": "Pagination cursors for navigating results",
                    "required": [
                      "next_cursor",
                      "prev_cursor"
                    ],
                    "additionalProperties": false
                  }
                },
                "description": "Response metadata including pagination",
                "required": [
                  "pagination"
                ],
                "additionalProperties": false
              }
            },
            "description": "Paginated list of environments with metadata containing pagination cursors",
            "required": [
              "data",
              "metadata"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "environments"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "search_events",
      "description": "Retrieves detailed information about events matching provided criteria. Returns comprehensive data including visitor_id, browser details, geolocation, bot detection, and various smart signals for fraud detection. Output can be large so consider only choosing products that you need and setting the limit to a dozen events or so. For schema of every individual event, see mcp resource fingerprint://schemas/event",
      "inputSchema": {
        "type": "object",
        "properties": {
          "anti_detect_browser": {
            "description": "Filter events by Anti-detect Browser Detection result.\n> Note: When using this parameter, only events with the `products.tampering.data.antiDetectBrowser` property set to `true` or `false` are returned. Events without a `products.tampering` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "bot": {
            "description": "Filter events by the Bot Detection result, specifically:\n  `all` - events where any kind of bot was detected.\n  `good` - events where a good bot was detected.\n  `bad` - events where a bad bot was detected.\n  `none` - events where no bot was detected.\n> Note: When using this parameter, only events with the `products.botd.data.bot.result` property set to a valid value are returned. Events without a `products.botd` Smart Signal result are left out of the response.\n",
            "enum": [
              "all",
              "good",
              "bad",
              "none"
            ],
            "type": "string"
          },
          "cloned_app": {
            "description": "Filter events by Cloned App Detection result.\n> Note: When using this parameter, only events with the `products.clonedApp.data.result` property set to `true` or `false` are returned. Events without a `products.clonedApp` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "datacenter": {
            "description": "Filter events by Datacenter Detection result.\n> Note: When using this parameter, only events with the `products.ipInfo.data.v4.datacenter.result` or `products.ipInfo.data.v6.datacenter.result` property set to `true` or `false` are returned. Events without a `products.ipInfo` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "developer_tools": {
            "description": "Filter events by Developer Tools detection result.\n> Note: When using this parameter, only events with the `products.developerTools.data.result` property set to `true` or `false` are returned. Events without a `products.developerTools` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "emulator": {
            "description": "Filter events by Android Emulator Detection result.\n> Note: When using this parameter, only events with the `products.emulator.data.result` property set to `true` or `false` are returned. Events without a `products.emulator` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "end": {
            "description": "Filter events with a timestamp smaller than the end time, in Unix time (milliseconds).\n",
            "type": "integer"
          },
          "environment": {
            "description": "Filter for events by providing one or more environment IDs.\n",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "factory_reset": {
            "description": "Filter events by Factory Reset Detection result.\n> Note: When using this parameter, only events with the `products.factoryReset.data.result` property set to `true` or `false` are returned. Events without a `products.factoryReset` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "frida": {
            "description": "Filter events by Frida Detection result.\n> Note: When using this parameter, only events with the `products.frida.data.result` property set to `true` or `false` are returned. Events without a `products.frida` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "incognito": {
            "description": "Filter events by Browser Incognito Detection result.\n> Note: When using this parameter, only events with the `products.incognito.data.result` property set to `true` or `false` are returned. Events without a `products.incognito` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "ip_address": {
            "description": "Filter events by IP address range. The range can be as specific as a single IP (/32 for IPv4 or /128 for IPv6)\nAll ip_address filters must use CIDR notation, for example, 10.0.0.0/24, 192.168.0.1/32\n",
            "type": "string"
          },
          "ip_blocklist": {
            "description": "Filter events by IP Blocklist Detection result.\n> Note: When using this parameter, only events with the `products.ipBlocklist.data.result` property set to `true` or `false` are returned. Events without a `products.ipBlocklist` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "jailbroken": {
            "description": "Filter events by Jailbroken Device Detection result.\n> Note: When using this parameter, only events with the `products.jailbroken.data.result` property set to `true` or `false` are returned. Events without a `products.jailbroken` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "limit": {
            "description": "Limit the number of events returned.\n",
            "minimum": 1,
            "type": "integer"
          },
          "linked_id": {
            "description": "Filter events by your custom identifier.\n\nYou can use [linked IDs](https://dev.fingerprint.com/reference/get-function#linkedid) to associate identification requests with your own identifier, for example, session ID, purchase ID, or transaction ID. You can then use this `linked_id` parameter to retrieve all events associated with your custom identifier.\n",
            "type": "string"
          },
          "location_spoofing": {
            "description": "Filter events by Location Spoofing detection result.\n> Note: When using this parameter, only events with the `products.locationSpoofing.data.result` property set to `true` or `false` are returned. Events without a `products.locationSpoofing` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "min_suspect_score": {
            "description": "Filter events with Suspect Score result above a provided minimum threshold.\n> Note: When using this parameter, only events where the `products.suspectScore.data.result` property set to a value exceeding your threshold are returned. Events without a `products.suspectScore` Smart Signal result are left out of the response.\n",
            "type": "number"
          },
          "mitm_attack": {
            "description": "Filter events by MITM (Man-in-the-Middle) Attack detection result.\n> Note: When using this parameter, only events with the `products.mitmAttack.data.result` property set to `true` or `false` are returned. Events without a `products.mitmAttack` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "pagination_key": {
            "description": "Use `pagination_key` to get the next page of results.\n\nWhen more results are available (e.g., you requested up to 200 results for your search using `limit`, but there are more than 200 events total matching your request), the `paginationKey` top-level attribute is added to the response. The key corresponds to the `timestamp` of the last returned event. In the following request, use that value in the `pagination_key` parameter to get the next page of results:\n\n1. First request, returning most recent 200 events: `GET api-base-url/events/search?limit=200`\n2. Use `response.paginationKey` to get the next page of results: `GET api-base-url/events/search?limit=200&pagination_key=1740815825085`\n",
            "type": "string"
          },
          "privacy_settings": {
            "description": "Filter events by Privacy Settings Detection result.\n> Note: When using this parameter, only events with the `products.privacySettings.data.result` property set to `true` or `false` are returned. Events without a `products.privacySettings` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "products": {
            "description": "Optional list of product fields to include in the response. If omitted all products are returned.",
            "items": {
              "enum": [
                "botd",
                "clonedApp",
                "developerTools",
                "emulator",
                "factoryReset",
                "frida",
                "highActivity",
                "identification",
                "incognito",
                "ipBlocklist",
                "ipInfo",
                "jailbroken",
                "locationSpoofing",
                "mitmAttack",
                "privacySettings",
                "proximity",
                "proxy",
                "rawDeviceAttributes",
                "remoteControl",
                "rootApps",
                "suspectScore",
                "tampering",
                "tor",
                "velocity",
                "virtualMachine",
                "vpn"
              ],
              "type": "string"
            },
            "type": "array"
          },
          "proximity_id": {
            "description": "Filter events by the most precise Proximity ID provided by default.\n> Note: When using this parameter, only events with the `products.proximity.id` property matching the provided ID are returned. Events without a `products.proximity` result are left out of the response.\n",
            "type": "string"
          },
          "proximity_precision_radius": {
            "description": "Filter events by Proximity Radius.\n> Note: When using this parameter, only events with the `products.proximity.precisionRadius` property set to a valid value are returned. Events without a `products.proximity` result are left out of the response.\n",
            "enum": [
              10,
              25,
              65,
              175,
              450,
              1200,
              3300,
              8500,
              22500
            ],
            "type": "integer"
          },
          "proxy": {
            "description": "Filter events by Proxy detection result.\n> Note: When using this parameter, only events with the `products.proxy.data.result` property set to `true` or `false` are returned. Events without a `products.proxy` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "reverse": {
            "description": "Sort events in reverse timestamp order.\n",
            "type": "boolean"
          },
          "root_apps": {
            "description": "Filter events by Rooted Device Detection result.\n> Note: When using this parameter, only events with the `products.rootApps.data.result` property set to `true` or `false` are returned. Events without a `products.rootApps` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "sdk_platform": {
            "description": "Filter events by the SDK Platform associated with the identification event.\n`js` - JavaScript agent (Web).\n`ios` - Apple iOS based devices.\n`android` - Android based devices.\n",
            "enum": [
              "js",
              "android",
              "ios"
            ],
            "type": "string"
          },
          "sdk_version": {
            "description": "Filter events by a specific SDK version associated with the identification event. Example: `3.11.14`\n",
            "type": "string"
          },
          "start": {
            "description": "Filter events with a timestamp greater than the start time, in Unix time (milliseconds).\n",
            "type": "integer"
          },
          "suspect": {
            "description": "Filter events previously tagged as suspicious via the [Update API](https://dev.fingerprint.com/reference/updateevent).\n> Note: When using this parameter, only events with the `suspect` property explicitly set to `true` or `false` are returned. Events with undefined `suspect` property are left out of the response.\n",
            "type": "boolean"
          },
          "tampering": {
            "description": "Filter events by Tampering Detection result.\n> Note: When using this parameter, only events with the `products.tampering.data.result` property set to `true` or `false` are returned. Events without a `products.tampering` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "virtual_machine": {
            "description": "Filter events by Virtual Machine Detection result.\n> Note: When using this parameter, only events with the `products.virtualMachine.data.result` property set to `true` or `false` are returned. Events without a `products.virtualMachine` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "visitor_id": {
            "description": "Unique [visitor identifier](https://dev.fingerprint.com/reference/get-function#visitorid) issued by Fingerprint Identification and all active Smart Signals.\nFilter for events matching this `visitor_id`.\n",
            "type": "string"
          },
          "vpn": {
            "description": "Filter events by VPN Detection result.\n> Note: When using this parameter, only events with the `products.vpn.data.result` property set to `true` or `false` are returned. Events without a `products.vpn` Smart Signal result are left out of the response.\n",
            "type": "boolean"
          },
          "vpn_confidence": {
            "description": "Filter events by VPN Detection result confidence level.\n`high` - events with high VPN Detection confidence.\n`medium` - events with medium VPN Detection confidence.\n`low` - events with low VPN Detection confidence.\n> Note: When using this parameter, only events with the `products.vpn.data.confidence` property set to a valid value are returned. Events without a `products.vpn` Smart Signal result are left out of the response.\n",
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "type": "string"
          }
        },
        "required": [
          "limit"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "events": {
            "$ref": "#/$defs/SearchEventsResponse"
          }
        },
        "required": [
          "events"
        ],
        "$defs": {
          "Botd": {
            "additionalProperties": false,
            "description": "Contains all the information from Bot Detection product",
            "properties": {
              "bot": {
                "$ref": "#/$defs/BotdBot"
              },
              "ip": {
                "description": "IP address of the requesting browser or bot.",
                "type": "string"
              },
              "linkedId": {
                "description": "A customer-provided id that was sent with the request.",
                "type": "string"
              },
              "meta": {
                "$ref": "#/$defs/Tag"
              },
              "requestId": {
                "description": "Unique identifier of the user's request.",
                "type": "string"
              },
              "time": {
                "description": "Time in UTC when the request from the JS agent was made. We recommend to treat requests that are older than 2 minutes as malicious. Otherwise, request replay attacks are possible.",
                "format": "date-time",
                "type": "string"
              },
              "url": {
                "description": "Page URL from which the request was sent.",
                "type": "string"
              },
              "userAgent": {
                "type": "string"
              }
            },
            "required": [
              "bot",
              "url",
              "ip",
              "time",
              "userAgent",
              "requestId"
            ],
            "type": "object"
          },
          "BotdBot": {
            "additionalProperties": false,
            "description": "Stores bot detection result",
            "properties": {
              "result": {
                "$ref": "#/$defs/BotdBotResult"
              },
              "type": {
                "type": "string"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "BotdBotResult": {
            "description": "Bot detection result:\n * `notDetected` - the visitor is not a bot\n * `good` - good bot detected, such as Google bot, Baidu Spider, AlexaBot and so on\n * `bad` - bad bot detected, such as Selenium, Puppeteer, Playwright, headless browsers, and so on\n",
            "enum": [
              "notDetected",
              "good",
              "bad"
            ],
            "type": "string"
          },
          "BrowserDetails": {
            "additionalProperties": false,
            "properties": {
              "browserFullVersion": {
                "type": "string"
              },
              "browserMajorVersion": {
                "type": "string"
              },
              "browserName": {
                "type": "string"
              },
              "device": {
                "type": "string"
              },
              "os": {
                "type": "string"
              },
              "osVersion": {
                "type": "string"
              },
              "userAgent": {
                "type": "string"
              }
            },
            "required": [
              "browserName",
              "browserFullVersion",
              "browserMajorVersion",
              "os",
              "osVersion",
              "device",
              "userAgent"
            ],
            "type": "object"
          },
          "ClonedApp": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "Android specific cloned application detection. There are 2 values: \n  * `true` - Presence of app cloners work detected (e.g. fully cloned application found or launch of it inside of a not main working profile detected).\n  * `false` - No signs of cloned application detected or the client is not Android.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "DeprecatedGeolocation": {
            "additionalProperties": false,
            "description": "This field is **deprecated** and will not return a result for **applications created after January 23rd, 2024**.  Please use the [IP Geolocation Smart signal](https://dev.fingerprint.com/docs/smart-signals-overview#ip-geolocation) for geolocation information.",
            "properties": {
              "accuracyRadius": {
                "description": "The IP address is likely to be within this radius (in km) of the specified location.",
                "minimum": 0,
                "type": "integer"
              },
              "city": {
                "$ref": "#/$defs/GeolocationCity"
              },
              "continent": {
                "$ref": "#/$defs/GeolocationContinent"
              },
              "country": {
                "$ref": "#/$defs/GeolocationCountry"
              },
              "latitude": {
                "maximum": 90,
                "minimum": -90,
                "type": "number"
              },
              "longitude": {
                "maximum": 180,
                "minimum": -180,
                "type": "number"
              },
              "postalCode": {
                "type": "string"
              },
              "subdivisions": {
                "$ref": "#/$defs/GeolocationSubdivisions"
              },
              "timezone": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "DeveloperTools": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "`true` if the browser is Chrome with DevTools open or Firefox with Developer Tools open, `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "Emulator": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "Android specific emulator detection. There are 2 values: \n  * `true` - Emulated environment detected (e.g. launch inside of AVD). \n  * `false` - No signs of emulated environment detected or the client is not Android.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "Error": {
            "additionalProperties": false,
            "properties": {
              "code": {
                "$ref": "#/$defs/ErrorCode"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ],
            "type": "object"
          },
          "ErrorCode": {
            "description": "Error code:\n * `RequestCannotBeParsed` - the query parameters or JSON payload contains some errors \n          that prevented us from parsing it (wrong type/surpassed limits).\n * `TokenRequired` - `Auth-API-Key` header is missing or empty.\n * `TokenNotFound` - no Fingerprint application found for specified secret key.\n * `SubscriptionNotActive` - Fingerprint application is not active.\n * `WrongRegion` - server and application region differ.\n * `FeatureNotEnabled` - this feature (for example, Delete API) is not enabled for your application.\n * `WorkspaceScopedSecretKeyRequired` - The provided secret API key is scoped to an environment, but this operation requires a workspace-scoped secret API key.\n * `RequestNotFound` - the specified request ID was not found. It never existed, expired, or it has been deleted.\n * `VisitorNotFound` - The specified visitor ID was not found. It never existed or it may have already been deleted.\n * `TooManyRequests` - the limit on secret API key requests per second has been exceeded.\n * `429 Too Many Requests` - the limit on secret API key requests per second has been exceeded.\n * `StateNotReady` - The event specified with request id is\n          not ready for updates yet. Try again.\n          This error happens in rare cases when update API is called immediately\n          after receiving the request id on the client. In case you need to send\n          information right away, we recommend using the JS agent API instead.\n * `Failed` - internal server error.\n",
            "enum": [
              "RequestCannotBeParsed",
              "TokenRequired",
              "TokenNotFound",
              "SubscriptionNotActive",
              "WrongRegion",
              "FeatureNotEnabled",
              "WorkspaceScopedSecretKeyRequired",
              "RequestNotFound",
              "VisitorNotFound",
              "TooManyRequests",
              "429 Too Many Requests",
              "StateNotReady",
              "Failed"
            ],
            "type": "string"
          },
          "EventsGetResponse": {
            "additionalProperties": false,
            "description": "Contains results from Fingerprint Identification and all active Smart Signals.",
            "properties": {
              "products": {
                "$ref": "#/$defs/Products"
              }
            },
            "required": [
              "products"
            ],
            "type": "object"
          },
          "FactoryReset": {
            "additionalProperties": false,
            "properties": {
              "time": {
                "description": "Indicates the time (in UTC) of the most recent factory reset that happened on the **mobile device**. \nWhen a factory reset cannot be detected on the mobile device or when the request is initiated from a browser,  this field will correspond to the *epoch* time (i.e 1 Jan 1970 UTC).\nSee [Factory Reset Detection](https://dev.fingerprint.com/docs/smart-signals-overview#factory-reset-detection) to learn more about this Smart Signal.\n",
                "format": "date-time",
                "type": "string"
              },
              "timestamp": {
                "description": "This field is just another representation of the value in the `time` field.\nThe time of the most recent factory reset that happened on the **mobile device** is expressed as Unix epoch time.\n",
                "type": "integer"
              }
            },
            "required": [
              "time",
              "timestamp"
            ],
            "type": "object"
          },
          "Frida": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "[Frida](https://frida.re/docs/) detection for Android and iOS devices. There are 2 values:\n  * `true` - Frida detected\n  * `false` - No signs of Frida or the client is not a mobile device.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "Geolocation": {
            "additionalProperties": false,
            "properties": {
              "accuracyRadius": {
                "description": "The IP address is likely to be within this radius (in km) of the specified location.",
                "minimum": 0,
                "type": "integer"
              },
              "city": {
                "$ref": "#/$defs/GeolocationCity"
              },
              "continent": {
                "$ref": "#/$defs/GeolocationContinent"
              },
              "country": {
                "$ref": "#/$defs/GeolocationCountry"
              },
              "latitude": {
                "maximum": 90,
                "minimum": -90,
                "type": "number"
              },
              "longitude": {
                "maximum": 180,
                "minimum": -180,
                "type": "number"
              },
              "postalCode": {
                "type": "string"
              },
              "subdivisions": {
                "$ref": "#/$defs/GeolocationSubdivisions"
              },
              "timezone": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "GeolocationCity": {
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "type": "object"
          },
          "GeolocationContinent": {
            "additionalProperties": false,
            "properties": {
              "code": {
                "maxLength": 2,
                "minLength": 2,
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "name"
            ],
            "type": "object"
          },
          "GeolocationCountry": {
            "additionalProperties": false,
            "properties": {
              "code": {
                "maxLength": 2,
                "minLength": 2,
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "name"
            ],
            "type": "object"
          },
          "GeolocationSubdivision": {
            "additionalProperties": false,
            "properties": {
              "isoCode": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "isoCode",
              "name"
            ],
            "type": "object"
          },
          "GeolocationSubdivisions": {
            "items": {
              "$ref": "#/$defs/GeolocationSubdivision"
            },
            "type": "array"
          },
          "HighActivity": {
            "additionalProperties": false,
            "properties": {
              "dailyRequests": {
                "description": "Number of requests from the same visitor in the previous day.",
                "minimum": 1,
                "type": "integer"
              },
              "result": {
                "description": "Flag indicating if the request came from a high-activity visitor.",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "IPBlocklist": {
            "additionalProperties": false,
            "properties": {
              "details": {
                "$ref": "#/$defs/IPBlocklistDetails"
              },
              "result": {
                "description": "`true` if request IP address is part of any database that we use to search for known malicious actors, `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result",
              "details"
            ],
            "type": "object"
          },
          "IPBlocklistDetails": {
            "additionalProperties": false,
            "properties": {
              "attackSource": {
                "description": "IP address was part of a known network attack (SSH/HTTPS).",
                "type": "boolean"
              },
              "emailSpam": {
                "description": "IP address was part of a known email spam attack (SMTP).",
                "type": "boolean"
              }
            },
            "required": [
              "emailSpam",
              "attackSource"
            ],
            "type": "object"
          },
          "IPInfo": {
            "additionalProperties": false,
            "description": "Details about the request IP address. Has separate fields for v4 and v6 IP address versions.",
            "properties": {
              "v4": {
                "$ref": "#/$defs/IPInfoV4"
              },
              "v6": {
                "$ref": "#/$defs/IPInfoV6"
              }
            },
            "type": "object"
          },
          "IPInfoASN": {
            "additionalProperties": false,
            "properties": {
              "asn": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "network": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            },
            "required": [
              "asn",
              "name",
              "network"
            ],
            "type": "object"
          },
          "IPInfoDataCenter": {
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "result": {
                "type": "boolean"
              }
            },
            "required": [
              "result",
              "name"
            ],
            "type": "object"
          },
          "IPInfoV4": {
            "additionalProperties": false,
            "properties": {
              "address": {
                "format": "ipv4",
                "type": "string"
              },
              "asn": {
                "$ref": "#/$defs/IPInfoASN"
              },
              "datacenter": {
                "$ref": "#/$defs/IPInfoDataCenter"
              },
              "geolocation": {
                "$ref": "#/$defs/Geolocation"
              }
            },
            "required": [
              "address",
              "geolocation"
            ],
            "type": "object"
          },
          "IPInfoV6": {
            "additionalProperties": false,
            "properties": {
              "address": {
                "format": "ipv6",
                "type": "string"
              },
              "asn": {
                "$ref": "#/$defs/IPInfoASN"
              },
              "datacenter": {
                "$ref": "#/$defs/IPInfoDataCenter"
              },
              "geolocation": {
                "$ref": "#/$defs/Geolocation"
              }
            },
            "required": [
