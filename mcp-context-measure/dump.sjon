          "Products": {
            "additionalProperties": false,
            "description": "Contains all information about the request identified by `requestId`, depending on the pricing plan (Pro, Pro Plus, Enterprise)",
            "properties": {
              "botd": {
                "$ref": "#/$defs/ProductBotd"
              },
              "clonedApp": {
                "$ref": "#/$defs/ProductClonedApp"
              },
              "developerTools": {
                "$ref": "#/$defs/ProductDeveloperTools"
              },
              "emulator": {
                "$ref": "#/$defs/ProductEmulator"
              },
              "factoryReset": {
                "$ref": "#/$defs/ProductFactoryReset"
              },
              "frida": {
                "$ref": "#/$defs/ProductFrida"
              },
              "highActivity": {
                "$ref": "#/$defs/ProductHighActivity"
              },
              "identification": {
                "$ref": "#/$defs/ProductIdentification"
              },
              "incognito": {
                "$ref": "#/$defs/ProductIncognito"
              },
              "ipBlocklist": {
                "$ref": "#/$defs/ProductIPBlocklist"
              },
              "ipInfo": {
                "$ref": "#/$defs/ProductIPInfo"
              },
              "jailbroken": {
                "$ref": "#/$defs/ProductJailbroken"
              },
              "locationSpoofing": {
                "$ref": "#/$defs/ProductLocationSpoofing"
              },
              "mitmAttack": {
                "$ref": "#/$defs/ProductMitMAttack"
              },
              "privacySettings": {
                "$ref": "#/$defs/ProductPrivacySettings"
              },
              "proximity": {
                "$ref": "#/$defs/ProductProximity"
              },
              "proxy": {
                "$ref": "#/$defs/ProductProxy"
              },
              "rawDeviceAttributes": {
                "$ref": "#/$defs/ProductRawDeviceAttributes"
              },
              "remoteControl": {
                "$ref": "#/$defs/ProductRemoteControl"
              },
              "rootApps": {
                "$ref": "#/$defs/ProductRootApps"
              },
              "suspectScore": {
                "$ref": "#/$defs/ProductSuspectScore"
              },
              "tampering": {
                "$ref": "#/$defs/ProductTampering"
              },
              "tor": {
                "$ref": "#/$defs/ProductTor"
              },
              "velocity": {
                "$ref": "#/$defs/ProductVelocity"
              },
              "virtualMachine": {
                "$ref": "#/$defs/ProductVirtualMachine"
              },
              "vpn": {
                "$ref": "#/$defs/ProductVPN"
              }
            },
            "type": "object"
          },
          "Proximity": {
            "additionalProperties": false,
            "description": "Proximity ID represents a fixed geographical zone in a discrete global grid within which the device is observed.\n",
            "properties": {
              "confidence": {
                "description": "A value between `0` and `1` representing the likelihood that the true device location lies within the mapped proximity zone.\n  * Scores closer to `1` indicate high confidence that the location is inside the mapped proximity zone.\n  * Scores closer to `0` indicate lower confidence, suggesting the true location may fall in an adjacent zone.\n",
                "maximum": 1,
                "minimum": 0,
                "type": "number"
              },
              "id": {
                "description": "A stable privacy-preserving identifier for a given proximity zone.\n",
                "type": "string"
              },
              "precisionRadius": {
                "description": "The radius of the proximity zone’s precision level, in meters.\n",
                "enum": [
                  10,
                  25,
                  65,
                  175,
                  450,
                  1200,
                  3300,
                  8500,
                  22500
                ],
                "type": "integer"
              }
            },
            "required": [
              "id",
              "precisionRadius",
              "confidence"
            ],
            "type": "object"
          },
          "Proxy": {
            "additionalProperties": false,
            "properties": {
              "confidence": {
                "$ref": "#/$defs/ProxyConfidence"
              },
              "details": {
                "$ref": "#/$defs/ProxyDetails"
              },
              "result": {
                "description": "IP address was used by a public proxy provider or belonged to a known recent residential proxy\n",
                "type": "boolean"
              }
            },
            "required": [
              "result",
              "confidence"
            ],
            "type": "object"
          },
          "ProxyConfidence": {
            "description": "Confidence level of the proxy detection.\nIf a proxy is not detected, confidence is \"high\".\nIf it's detected, can be \"low\", \"medium\", or \"high\".\n",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "ProxyDetails": {
            "additionalProperties": false,
            "description": "Proxy detection details (present if proxy is detected)",
            "properties": {
              "lastSeenAt": {
                "description": "ISO 8601 formatted timestamp in UTC with hourly resolution\nof when this IP was last seen as a proxy when available.\n",
                "format": "date-time",
                "type": "string"
              },
              "proxyType": {
                "description": "Residential proxies use real user IP addresses to appear as legitimate traffic, \nwhile data center proxies are public proxies hosted in data centers\n",
                "enum": [
                  "residential",
                  "data_center"
                ],
                "type": "string"
              }
            },
            "required": [
              "proxyType"
            ],
            "type": [
              "object",
              "null"
            ]
          },
          "RawDeviceAttribute": {
            "additionalProperties": false,
            "properties": {
              "error": {
                "$ref": "#/$defs/RawDeviceAttributeError"
              },
              "value": {
                "title": "value"
              }
            },
            "type": "object"
          },
          "RawDeviceAttributeError": {
            "additionalProperties": false,
            "properties": {
              "message": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "RawDeviceAttributes": {
            "additionalProperties": {
              "$ref": "#/$defs/RawDeviceAttribute"
            },
            "description": "It includes 35+ raw browser identification attributes to provide Fingerprint users with even more information than our standard visitor ID provides. This enables Fingerprint users to not have to run our open-source product in conjunction with Fingerprint Pro Plus and Enterprise to get those additional attributes.\nWarning: The raw signals data can change at any moment as we improve the product. We cannot guarantee the internal shape of raw device attributes to be stable, so typical semantic versioning rules do not apply here. Use this data with caution without assuming a specific structure beyond the generic type provided here.\n",
            "type": "object"
          },
          "RemoteControl": {
            "additionalProperties": false,
            "description": "This signal is deprecated.\n",
            "properties": {
              "result": {
                "description": "`true` if the request came from a machine being remotely controlled (e.g. TeamViewer), `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "RootApps": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "Android specific root management apps detection. There are 2 values: \n  * `true` - Root Management Apps detected (e.g. Magisk).\n  * `false` - No Root Management Apps detected or the client isn't Android.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "SDK": {
            "additionalProperties": false,
            "description": "Contains information about the SDK used to perform the request.",
            "properties": {
              "integrations": {
                "items": {
                  "$ref": "#/$defs/Integration"
                },
                "type": "array"
              },
              "platform": {
                "description": "Platform of the SDK.",
                "type": "string"
              },
              "version": {
                "description": "SDK version string.",
                "type": "string"
              }
            },
            "required": [
              "platform",
              "version"
            ],
            "type": "object"
          },
          "SearchEventsResponse": {
            "additionalProperties": false,
            "description": "Contains a list of all identification events matching the specified search criteria.",
            "properties": {
              "events": {
                "items": {
                  "description": "Device intelligence results for the identification event.",
                  "properties": {
                    "products": {
                      "$ref": "#/$defs/Products"
                    }
                  },
                  "required": [
                    "products"
                  ],
                  "type": "object"
                },
                "type": "array"
              },
              "paginationKey": {
                "description": "Use this value in the `pagination_key` parameter to request the next page of search results.",
                "type": "string"
              }
            },
            "type": "object"
          },
          "SuspectScore": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "Suspect Score is an easy way to integrate Smart Signals into your fraud protection work flow.  It is a weighted representation of all Smart Signals present in the payload that helps identify suspicious activity. The value range is [0; S] where S is sum of all Smart Signals weights.  See more details here: https://dev.fingerprint.com/docs/suspect-score\n",
                "type": "integer"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "Tag": {
            "additionalProperties": true,
            "description": "A customer-provided value or an object that was sent with identification request.",
            "type": "object"
          },
          "Tampering": {
            "additionalProperties": false,
            "properties": {
              "anomalyScore": {
                "description": "A score that indicates the extent of anomalous data in the request. This field applies to requests originating from **both** browsers and Android SDKs. \n  * Values above `0.5` indicate that the request has been tampered with.\n  * Values below `0.5` indicate that the request is genuine.\n",
                "maximum": 1,
                "minimum": 0,
                "type": "number"
              },
              "antiDetectBrowser": {
                "description": "Anti-detect browsers try to evade identification by masking or manipulating their fingerprint to imitate legitimate browser configurations. This field does not apply to requests originating from mobile SDKs.\n  * `true` - The browser resembles a known anti-detect browser, for example, Incognition.\n  * `false` - The browser does not resemble an anti-detect browser or the request originates from a mobile SDK.\n",
                "type": "boolean"
              },
              "result": {
                "description": "Indicates if an identification request from a browser or an Android SDK has been tampered with. Not supported in the iOS SDK, is always `false` for iOS requests.\n  * `true` - If the request meets either of the following conditions:\n    * Contains anomalous browser or device attributes that could not have been legitimately produced by the JavaScript agent or the Android SDK (see `anomalyScore`).\n    * Originated from an anti-detect browser like Incognition (see `antiDetectBrowser`).\n  * `false` - If the request is considered genuine or was generated by the iOS SDK.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result",
              "anomalyScore",
              "antiDetectBrowser"
            ],
            "type": "object"
          },
          "Tor": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "`true` if the request IP address is a known tor exit node, `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          },
          "VPN": {
            "additionalProperties": false,
            "properties": {
              "confidence": {
                "$ref": "#/$defs/VPNConfidence"
              },
              "methods": {
                "$ref": "#/$defs/VPNMethods"
              },
              "originCountry": {
                "description": "Country of the request (only for Android SDK version >= 2.4.0, ISO 3166 format or unknown).",
                "type": "string"
              },
              "originTimezone": {
                "description": "Local timezone which is used in timezoneMismatch method.",
                "type": "string"
              },
              "result": {
                "description": "VPN or other anonymizing service has been used when sending the request.",
                "type": "boolean"
              }
            },
            "required": [
              "result",
              "confidence",
              "originTimezone",
              "originCountry",
              "methods"
            ],
            "type": "object"
          },
          "VPNConfidence": {
            "description": "A confidence rating for the VPN detection result — \"low\", \"medium\", or \"high\". Depends on the combination of results returned from all VPN detection methods.",
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "VPNMethods": {
            "additionalProperties": false,
            "properties": {
              "auxiliaryMobile": {
                "description": "This method applies to mobile devices only. Indicates the result of additional methods used to detect a VPN in mobile devices.",
                "type": "boolean"
              },
              "osMismatch": {
                "description": "The browser runs on a different operating system than the operating system inferred from the request network signature.",
                "type": "boolean"
              },
              "publicVPN": {
                "description": "Request IP address is owned and used by a public VPN service provider.",
                "type": "boolean"
              },
              "relay": {
                "description": "Request IP address belongs to a relay service provider, indicating the use of relay services like [Apple Private relay](https://support.apple.com/en-us/102602) or [Cloudflare Warp](https://developers.cloudflare.com/warp-client/). \n\n* Like VPNs, relay services anonymize the visitor's true IP address.\n* Unlike traditional VPNs, relay services don't let visitors spoof their location by choosing an exit node in a different country.\n\nThis field allows you to differentiate VPN users and relay service users in your fraud prevention logic.\n",
                "type": "boolean"
              },
              "timezoneMismatch": {
                "description": "The browser timezone doesn't match the timezone inferred from the request IP address.",
                "type": "boolean"
              }
            },
            "required": [
              "timezoneMismatch",
              "publicVPN",
              "auxiliaryMobile",
              "osMismatch",
              "relay"
            ],
            "type": "object"
          },
          "Velocity": {
            "additionalProperties": false,
            "description": "Sums key data points for a specific `visitorId`, `ipAddress` and `linkedId` at three distinct time\nintervals: 5 minutes, 1 hour, and 24 hours as follows: \n\n- Number of distinct IP addresses associated to the visitor ID.\n- Number of distinct linked IDs associated with the visitor ID.\n- Number of distinct countries associated with the visitor ID.\n- Number of identification events associated with the visitor ID.\n- Number of identification events associated with the detected IP address.\n- Number of distinct IP addresses associated with the provided linked ID.\n- Number of distinct visitor IDs associated with the provided linked ID.\n\nThe `24h` interval of `distinctIp`, `distinctLinkedId`, `distinctCountry`,\n`distinctIpByLinkedId` and `distinctVisitorIdByLinkedId` will be omitted \nif the number of `events` for the visitor ID in the last 24\nhours (`events.intervals.['24h']`) is higher than 20.000.\n",
            "properties": {
              "distinctCountry": {
                "$ref": "#/$defs/VelocityData"
              },
              "distinctIp": {
                "$ref": "#/$defs/VelocityData"
              },
              "distinctIpByLinkedId": {
                "$ref": "#/$defs/VelocityData"
              },
              "distinctLinkedId": {
                "$ref": "#/$defs/VelocityData"
              },
              "distinctVisitorIdByLinkedId": {
                "$ref": "#/$defs/VelocityData"
              },
              "events": {
                "$ref": "#/$defs/VelocityData"
              },
              "ipEvents": {
                "$ref": "#/$defs/VelocityData"
              }
            },
            "required": [
              "distinctIp",
              "distinctLinkedId",
              "distinctCountry",
              "events",
              "ipEvents",
              "distinctIpByLinkedId",
              "distinctVisitorIdByLinkedId"
            ],
            "type": "object"
          },
          "VelocityData": {
            "additionalProperties": false,
            "properties": {
              "intervals": {
                "$ref": "#/$defs/VelocityIntervals"
              }
            },
            "type": "object"
          },
          "VelocityIntervals": {
            "additionalProperties": false,
            "description": "Is absent if the velocity data could not be generated for the visitor ID.\n",
            "properties": {
              "1h": {
                "type": "integer"
              },
              "24h": {
                "description": "The `24h` interval of `distinctIp`, `distinctLinkedId`, `distinctCountry`, `distinctIpByLinkedId` and `distinctVisitorIdByLinkedId` will be omitted if the number of `events`` for the visitor ID in the last 24 hours (`events.intervals.['24h']`) is higher than 20.000.\n",
                "type": "integer"
              },
              "5m": {
                "type": "integer"
              }
            },
            "required": [
              "5m",
              "1h"
            ],
            "type": "object"
          },
          "VirtualMachine": {
            "additionalProperties": false,
            "properties": {
              "result": {
                "description": "`true` if the request came from a browser running inside a virtual machine (e.g. VMWare), `false` otherwise.\n",
                "type": "boolean"
              }
            },
            "required": [
              "result"
            ],
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "update_api_key",
      "description": "Updates an existing API key. Can change name, description, status (enabled/disabled), and rate limit. Only provided fields are changed. For schema, see mcp resource fingerprint://schemas/api-key",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "API key identifier"
          },
          "name": {
            "type": [
              "null",
              "string"
            ],
            "description": "API key display name (3-255 characters)"
          },
          "description": {
            "type": [
              "null",
              "string"
            ],
            "description": "API key description (3-255 characters)"
          },
          "status": {
            "type": [
              "null",
              "string"
            ],
            "description": "Enable or disable the key. Values: enabled, disabled"
          },
          "rate_limit": {
            "type": [
              "null",
              "number"
            ],
            "description": "Requests-per-second limit. Minimum: 0.1"
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "api_key": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Auto-generated API key identifier"
              },
              "name": {
                "type": "string",
                "description": "API key display name"
              },
              "description": {
                "type": "string",
                "description": "API key description"
              },
              "status": {
                "type": "string",
                "description": "API key status. Values: enabled, disabled"
              },
              "environment": {
                "description": "Associated environment. Null if scoped to the workspace"
              },
              "type": {
                "type": "string",
                "description": "API key type. Values: public, secret, proxy"
              },
              "token": {
                "type": "string",
                "description": "API key value. Secret keys are only visible at creation time"
              },
              "rate_limit": {
                "type": "number",
                "description": "Requests-per-second limit for this key"
              },
              "created_at": {
                "type": "string",
                "description": "Timestamp when the API key was created"
              },
              "disabled_at": {
                "type": [
                  "null",
                  "string"
                ],
                "description": "Timestamp when the API key was disabled"
              }
            },
            "description": "The updated API key with id, name, description, status, environment, type, token, rate_limit, created_at, and disabled_at",
            "required": [
              "id",
              "name",
              "description",
              "status",
              "environment",
              "type",
              "token",
              "rate_limit",
              "created_at",
              "disabled_at"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "api_key"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "update_environment",
      "description": "Updates an existing workspace environment. Only provided fields are changed. For schema, see mcp resource fingerprint://schemas/environment",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Environment identifier"
          },
          "name": {
            "type": [
              "null",
              "string"
            ],
            "description": "Environment display name (max 255 characters)"
          },
          "description": {
            "type": [
              "null",
              "string"
            ],
            "description": "Environment description (max 256 characters)"
          },
          "limit_mode": {
            "type": [
              "null",
              "string"
            ],
            "description": "Limit behavior mode. Values: none, restrict, notify"
          },
          "limit_value": {
            "type": [
              "null",
              "integer"
            ],
            "description": "Threshold value. Required if limit_mode is not none"
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "environment": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Auto-generated environment identifier"
              },
              "name": {
                "type": "string",
                "description": "Environment display name"
              },
              "description": {
                "type": "string",
                "description": "Environment description (max 256 characters)"
              },
              "limit_mode": {
                "type": "string",
                "description": "Limit behavior mode. Values: none, restrict, notify"
              },
              "limit_value": {
                "type": "integer",
                "description": "Threshold value. Required if limit_mode is not none. Minimum: 1"
              },
              "is_restricted": {
                "type": "boolean",
                "description": "Whether the environment is currently restricted"
              },
              "restricted_at": {
                "type": [
                  "null",
                  "string"
                ],
                "description": "Timestamp when the environment was restricted"
              },
              "created_at": {
                "type": "string",
                "description": "Timestamp when the environment was created"
              },
              "updated_at": {
                "type": [
                  "null",
                  "string"
                ],
                "description": "Timestamp when the environment was last updated"
              }
            },
            "description": "The updated environment with id, name, description, limit_mode, limit_value, is_restricted, restricted_at, created_at, and updated_at",
            "required": [
              "id",
              "name",
              "description",
              "limit_mode",
              "limit_value",
              "is_restricted",
              "restricted_at",
              "created_at",
              "updated_at"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "environment"
        ],
        "additionalProperties": false
      }
    }
  ],
  "resources": [
    {
      "name": "api_key_schema",
      "title": "API Key JSON Schema",
      "uri": "fingerprint://schemas/api-key",
      "description": "JSON Schema for API key objects returned by API key management tools",
      "mimeType": "application/schema+json"
    },
